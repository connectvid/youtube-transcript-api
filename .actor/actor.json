{
    "actorSpecification": 1,
    "name": "youtube-transcript-api",
    "title": "YouTube Transcript API",
    "description": "Extract transcripts, captions, and subtitles from YouTube videos. Supports 100+ languages, auto-generated captions, SRT/VTT export, playlists, and channels.",
    "version": "0.1",
    "meta": {
        "templateId": "ts-start"
    },
    "input": "./input_schema.json",
    "dockerfile": "./Dockerfile",
    "minMemoryMbytes": 256,
    "maxMemoryMbytes": 1024,
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "title": "YouTube Transcripts",
            "fields": {
                "type": "object",
                "properties": {
                    "url": { "type": ["string", "null"], "title": "Video URL", "format": "link", "rarity": "always" },
                    "videoId": { "type": ["string", "null"], "title": "Video ID", "rarity": "always" },
                    "title": { "type": ["string", "null"], "title": "Title", "rarity": "always" },
                    "channelName": { "type": ["string", "null"], "title": "Channel Name", "rarity": "common" },
                    "channelUrl": { "type": ["string", "null"], "title": "Channel URL", "format": "link", "rarity": "common" },
                    "description": { "type": ["string", "null"], "title": "Description", "rarity": "common" },
                    "viewCount": { "type": ["integer", "null"], "title": "View Count", "rarity": "common" },
                    "publishDate": { "type": ["string", "null"], "title": "Publish Date", "rarity": "common" },
                    "duration": { "type": ["string", "null"], "title": "Duration", "rarity": "common" },
                    "thumbnailUrl": { "type": ["string", "null"], "title": "Thumbnail URL", "format": "image", "rarity": "common" },
                    "language": { "type": ["string", "null"], "title": "Language", "rarity": "always" },
                    "languageName": { "type": ["string", "null"], "title": "Language Name", "rarity": "always" },
                    "isAutoGenerated": { "type": ["boolean", "null"], "title": "Auto-Generated", "rarity": "always" },
                    "isTranslated": { "type": ["boolean", "null"], "title": "Translated", "rarity": "always" },
                    "availableLanguages": { "type": ["array", "null"], "title": "Available Languages", "rarity": "always" },
                    "transcript": { "type": ["array", "null"], "title": "Transcript Segments", "rarity": "common" },
                    "fullText": { "type": ["string", "null"], "title": "Full Text", "rarity": "always" },
                    "formattedTranscript": { "type": ["string", "null"], "title": "Formatted Transcript (SRT/VTT)", "rarity": "rare" },
                    "segmentCount": { "type": ["integer", "null"], "title": "Segment Count", "rarity": "always" },
                    "totalDurationSecs": { "type": ["integer", "null"], "title": "Total Duration (seconds)", "rarity": "always" },
                    "scrapedAt": { "type": ["string", "null"], "title": "Scraped At", "rarity": "always" }
                }
            },
            "views": {
                "overview": {
                    "title": "Overview",
                    "transformation": {
                        "fields": ["videoId", "title", "language", "isAutoGenerated", "segmentCount", "fullText"]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "videoId": { "label": "Video ID", "format": "text" },
                            "title": { "label": "Title", "format": "text" },
                            "language": { "label": "Language", "format": "text" },
                            "isAutoGenerated": { "label": "Auto-Generated", "format": "boolean" },
                            "segmentCount": { "label": "Segments", "format": "number" },
                            "fullText": { "label": "Transcript", "format": "text" }
                        }
                    }
                },
                "detailed": {
                    "title": "Full Details",
                    "transformation": {
                        "fields": ["url", "videoId", "title", "channelName", "publishDate", "viewCount", "language", "isAutoGenerated", "isTranslated", "availableLanguages", "segmentCount", "totalDurationSecs", "fullText"]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "url": { "label": "URL", "format": "link" },
                            "videoId": { "label": "Video ID", "format": "text" },
                            "title": { "label": "Title", "format": "text" },
                            "channelName": { "label": "Channel", "format": "text" },
                            "publishDate": { "label": "Published", "format": "text" },
                            "viewCount": { "label": "Views", "format": "number" },
                            "language": { "label": "Language", "format": "text" },
                            "isAutoGenerated": { "label": "Auto", "format": "boolean" },
                            "isTranslated": { "label": "Translated", "format": "boolean" },
                            "availableLanguages": { "label": "Available Languages", "format": "text" },
                            "segmentCount": { "label": "Segments", "format": "number" },
                            "totalDurationSecs": { "label": "Duration (s)", "format": "number" },
                            "fullText": { "label": "Full Text", "format": "text" }
                        }
                    }
                }
            }
        }
    }
}
